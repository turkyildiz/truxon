.env
.env.local
node_modules/
dist/
.DS_Store
.claude/
node_modules

# Firebase config (per build machine; not committed)
mobile/android/app/google-services.json

# Fuel fetcher: secrets + persisted AtoB browser session (never commit)
deploy/fuel/fuel.env
deploy/fuel/.atob-profile/
deploy/fuel/fuel.log

# ITS delta fetcher: secrets, persisted session, captured load data (never commit)
deploy/migration-its/its.env
deploy/migration-its/.its-profile/
deploy/migration-its/its.log
deploy/migration-its/its_delta/
deploy/migration-its/its_loads_full.json
deploy/migration-its/load_id_map.json
deploy/migration-its/punchlist.json
deploy/migration-its/files/

# NAS vision enrichment: env (public token, but keep NAS-only) + logs
deploy/vision-enrich/vision.env
deploy/vision-enrich/logs/

# NAS doc-rag indexer: env (public token) + logs
deploy/doc-rag/rag.env
deploy/doc-rag/logs/

# Dropbox → Team Drive bulk import: env, staged bytes, manifest (never commit)
deploy/drive-import/drive.env
deploy/drive-import/.stage/
deploy/drive-import/manifest.json
mobile/android/build/
deploy/tolls/__pycache__/

# OTA / signing private keys — MUST never be committed
*-ota-signing.pem
*.pem
truxon-ota-signing.pem
