# Copy to /volume1/docker/truxon-llm-proxy/proxy.env on the NAS (chmod 600).
# The real file is NOT in git — it holds the shared secret.

# Where Ollama listens on the NAS host (host-network container).
OLLAMA_URL=http://127.0.0.1:11434

# Shared bearer token. Must equal the LOCAL_LLM_KEY Supabase secret.
# Generate: openssl rand -hex 32
LOCAL_LLM_KEY=replace-me

# Port this proxy listens on (Tailscale Funnel maps public :8443 here).
PORT=11435
