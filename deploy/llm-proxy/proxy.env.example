# Copy to /volume1/docker/truxon-llm-proxy/proxy.env on the NAS (chmod 600).
# The real file is NOT in git — it holds the shared secret.

# Where Ollama listens on the NAS host (host-network container).
OLLAMA_URL=http://127.0.0.1:11434

# Shared bearer token. Must equal the LOCAL_LLM_KEY Supabase secret.
# Generate: openssl rand -hex 32
LOCAL_LLM_KEY=replace-me

# Port this proxy listens on (Tailscale Funnel maps public :8443 here).
PORT=11435

# Heavy-model routing to the Lynx GPU box (optional). If set, models whose name
# contains any HEAVY_MODELS token are sent to LYNX_OLLAMA_URL; all else -> NAS.
# Falls back to NAS automatically if Lynx is unreachable.
LYNX_OLLAMA_URL=http://100.110.143.84:11434
HEAVY_MODELS=qwen2.5:7b,qwen2.5vl:7b
