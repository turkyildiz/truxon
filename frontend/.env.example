# Copy to .env.local (gitignored). Values come from your Supabase project:
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Notes:
# - The anon key is safe to expose in the browser; row-level security
#   enforces access. Never put the service_role key here.
# - Server-side secrets (LLM_API_KEY, GOOGLE_MAPS_API_KEY, and the optional
#   LLM_BASE_URL / LLM_MODEL overrides) are NOT set here — they live in
#   Supabase edge-function secrets (see README).
